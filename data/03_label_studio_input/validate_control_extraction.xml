<View>
  <Header value="UAE IA Control Extraction - Validation and Correction" size="4"/>
  
  <View style="background: #f5f5f5; padding: 10px; margin-bottom: 10px;">
    <Text name="control_id" value="Control ID: $control_id" style="font-weight: bold;"/>
    <Text name="control_family" value="Family: $control_family"/>
    <Text name="control_subfamily" value="Sub-family: $control_subfamily"/>
    <Header value="Extracted Control Name:" size="5"/>
    <Text name="control_name" value="$control_name"/>
    
    <Header value="Extracted Description:" size="5"/>
    <TextArea name="control_description" value="$control_description" 
              toName="control_description" rows="5" editable="true" 
              placeholder="Review and correct the extracted control description..."/>
    
    <Header value="Extracted Sub-Controls:" size="5"/>
    <TextArea name="sub_controls" value="$sub_controls" 
              toName="sub_controls" rows="8" editable="true"
              placeholder="Review and correct sub-controls (one per line)..."/>
    
    <Header value="Extracted Implementation Guidelines:" size="5"/>
    <TextArea name="implementation_guidelines" value="$implementation_guidelines"
              toName="implementation_guidelines" rows="6" editable="true"
              placeholder="Review and correct implementation guidelines..."/>
    
    <Header value="Extracted External Factors:" size="5"/>
    <TextArea name="external_factors" value="$external_factors"
              toName="external_factors" rows="4" editable="true"
              placeholder="Review and correct external factors..."/>
    
    <Header value="Extracted Internal Factors:" size="5"/>
    <TextArea name="internal_factors" value="$internal_factors"
              toName="internal_factors" rows="4" editable="true"
              placeholder="Review and correct internal factors..."/>
    
    <Header value="Extracted Guidance Points:" size="5"/>
    <TextArea name="guidance_points" value="$guidance_points"
              toName="guidance_points" rows="4" editable="true"
              placeholder="Review and correct guidance points..."/>
  </View>

  <Header value="Validation Status" size="4"/>
  <Choices name="validation_status" toName="control_description" required="true" showInLine="true">
    <Choice value="Complete" alias="Complete" background="#d4edda"/>
    <Choice value="Needs Correction" alias="Needs Fix" background="#fff3cd"/>
    <Choice value="Missing Content" alias="Missing" background="#f8d7da"/>
  </Choices>

  <Header value="Notes / Corrections" size="5"/>
  <TextArea name="correction_notes" toName="control_description" 
            placeholder="Add notes about what was corrected or what's missing..." 
            rows="3" editable="true"/>
</View>
